# ============================================================
# NetOps AI Platform — Environment Variables Template
# COPY THIS FILE TO .env ONLY FOR LOCAL DEV/LAB
# NEVER COMMIT .env TO GIT
# IN PRODUCTION: use Docker Secrets (see docs/PREMISSAS.md PG-01-D)
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops
POSTGRES_USER=netops_user
POSTGRES_PASSWORD=CHANGE_ME

# --- NSX-T Collector ---
# TOKEN: injected via Docker Secret in production (never here)
# For local lab only:
# NSX_API_TOKEN=CHANGE_ME
NSX_MANAGER_URL=https://nsx-manager.example.com
NSX_VERIFY_SSL=true
NSX_COLLECT_INTERVAL_SECONDS=300

# --- Backend API ---
API_PORT=8080
API_SECRET_KEY=CHANGE_ME_RANDOM_STRING

# --- Frontend ---
REACT_APP_API_URL=http://localhost:8080

# --- AI Pipeline (Phase 1+) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b
# LITELLM_PROXY_URL=http://localhost:4000
# GEMINI_API_KEY=CHANGE_ME  # Only if using Gemini — sanitize data before sending
