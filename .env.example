# ============================================================
# NetOps AI Platform — Environment Variables Template
# COPY THIS FILE TO .env ONLY FOR LOCAL DEV/LAB
# NEVER COMMIT .env TO GIT
# IN PRODUCTION: use Docker Secrets (see scripts/deploy-phase0.sh)
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops
POSTGRES_USER=netops_user
# POSTGRES_PASSWORD → Docker Secret — never here

# --- Module: nsx-collector ---
NSX_MANAGER_URL=https://nsx-manager.example.com
NSX_VERIFY_SSL=true
NSX_COLLECT_INTERVAL_SECONDS=300
# NSX_API_TOKEN → Docker Secret — never here

# --- Core: communication/backend ---
API_PORT=8080
# API_SECRET_KEY → Docker Secret — never here

# --- Core: communication/frontend ---
REACT_APP_API_URL=http://localhost:8080
FRONTEND_PORT=3000

# --- Core: cognition (Phase 1+) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b
# GEMINI_API_KEY → Docker Secret — never here
